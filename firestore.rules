rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read on listings — anyone can browse
    // Write allowed for demo/hackathon — restrict with auth in production
    match /found_items/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /lost_items/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /matches/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
